<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/base.xml"/>

    <appender name="AWS_CLOUDWATCH" class="ca.pjer.logback.AwsLogsAppender">
        <layout>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </layout>

        <logGroupName>TestPaymentService-Logs</logGroupName>
        <logStreamUuidPrefix>execucao-</logStreamUuidPrefix>
        <region>us-east-1</region>

        <accessKeyId>${ACESS_LOGS_KEY}</accessKeyId>
        <secretAccessKey>${ACESS_LOGS_SECRET_KEY}</secretAccessKey>
    </appender>

    <root level="INFO">
        <appender-ref ref="AWS_CLOUDWATCH" />
    </root>
</configuration>